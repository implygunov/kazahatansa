# ===== Cloudflare Turnstile (капча) =====
# Возьми оба ключа тут: https://dash.cloudflare.com -> Turnstile -> твой виджет.
# Просто вставь значения после "=" (без кавычек, без пробелов).

# Публичный ключ (показывается в браузере), вида 0x4AAAAAA...
TURNSTILE_SITEKEY=0x4AAAAAADgVliHvT40_fbeW

# Секретный ключ (только на сервере, никому не показывай!), вида 0x4AAAAAA...
# Пока пусто — проверка капчи на сервере отключена и НЕ мешает регистрации.
TURNSTILE_SECRET=0x4AAAAAADgVlhZEqFGyhZgiVBBjffF_vUk
