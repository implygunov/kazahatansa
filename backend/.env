# ===== Cloudflare Turnstile (капча) =====
# Возьми оба ключа тут: https://dash.cloudflare.com -> Turnstile -> твой виджет.
# Просто вставь значения после "=" (без кавычек, без пробелов).

# Публичный ключ (показывается в браузере), вида 0x4AAAAAA...
TURNSTILE_SITEKEY=0x4AAAAAADgVliHvT40_fbeW

# Секретный ключ (только на сервере, никому не показывай!), вида 0x4AAAAAA...
# Пока пусто — проверка капчи на сервере отключена и НЕ мешает регистрации.
TURNSTILE_SECRET=0x4AAAAAADgVlhZEqFGyhZgiVBBjffF_vUk

# ===== Протект клиента (Pillar A/B) =====
# Ключ транспортного шифрования jar (AES-256-GCM, формат KZC1). 64 hex.
JAR_ENC_KEY=35777cd8e94cc8b7a10ee38a0e4a95b5ee04843c2968334cc7982aa59d4c53d4
# Путь к ЗАЩИЩЁННОМУ (классо-зашифрованному) jar — выход gradle-задачи encryptClasses.
JAR_SOURCE_PATH=C:\crydlc\backend\files\client.jar
# Ключ расшифровки классов (K). Тот же, что передаётся gradle-задаче encryptClasses.
# Ротируй на каждую сборку. 64 hex.
KZC_CLASS_KEY=1e67f0aa95d1c4588bece849377214e3371eedf1c47258731bf5cbbe84204a44
# Путь к kzc-agent.jar (раздаётся лаунчеру через /api/download/agent).
AGENT_SOURCE_PATH=C:\crydlc\backend\files\kzc-agent.jar
